{
	"name": "svelte",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"proto": "deno run --allow-all --node-modules-dir npm:protobufjs-cli/pbjs -t static-module -w es6 -o src/lib/proto/freshmeal.js schema/freshmeal.proto && deno run --allow-all --node-modules-dir npm:protobufjs-cli/pbts -o src/lib/proto/freshmeal.d.ts src/lib/proto/freshmeal.js"
	},
	"dependencies": {
		"leaflet": "^1.9.4",
		"long": "^5.3.2",
		"protobufjs": "^8.6.5"
	},
	"devDependencies": {
		"@types/leaflet": "^1.9.21",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.69.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"typescript": "^6.0.3",
		"vite": "^8.1.2"
	}
}
